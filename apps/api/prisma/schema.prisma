generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model cases {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  access_code      String    @unique
  description      String?
  status           String    @default("ACTIVE")
  created_at       DateTime  @default(now()) @db.Timestamptz
  closed_at        DateTime? @db.Timestamptz
  last_briefing_at DateTime? @db.Timestamptz

  domains                   domains[]
  signals                   signals[]
  signal_events             signal_events[]
  admission_audit           admission_audit[]
  admission_audit_sealed    admission_audit_sealed[]
  score_change_audit        score_change_audit[]
  signal_connections        signal_connections[]
  contradictions            contradictions[]
  released_options          released_options[]
  competition_sets          competition_sets[]
  hypotheses                hypotheses[]
  frame_entities            frame_entity[]
  hypothesis_evidence       hypothesis_evidence[]
  residual_instances        residual_instance[]
  residual_lineages         residual_lineage[]
  residual_interventions    residual_intervention[]
  briefings                 briefings[]
}

model domains {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id     String   @db.Uuid
  name        String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz

  case                    cases                @relation(fields: [case_id], references: [id], onDelete: Cascade)
  signals                 signals[]
  connections_as_a        signal_connections[] @relation("domain_a")
  connections_as_b        signal_connections[] @relation("domain_b")
  independence_as_a       domain_independence[] @relation("ind_domain_a")
  independence_as_b       domain_independence[] @relation("ind_domain_b")
  independence_history_a  domain_independence_history[] @relation("hist_domain_a")
  independence_history_b  domain_independence_history[] @relation("hist_domain_b")

  @@unique([case_id, name])
  @@index([case_id])
}

model domain_independence {
  domain_a_id        String   @db.Uuid
  domain_b_id        String   @db.Uuid
  is_independent     Boolean  @default(true)
  independence_basis String?
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @db.Timestamptz

  domainA  domains @relation("ind_domain_a", fields: [domain_a_id], references: [id])
  domainB  domains @relation("ind_domain_b", fields: [domain_b_id], references: [id])

  @@id([domain_a_id, domain_b_id])
}

model domain_independence_history {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain_a_id        String   @db.Uuid
  domain_b_id        String   @db.Uuid
  before_independent Boolean?
  after_independent  Boolean
  change_reason      String?
  changed_at         DateTime @default(now()) @db.Timestamptz

  domainA domains @relation("hist_domain_a", fields: [domain_a_id], references: [id])
  domainB domains @relation("hist_domain_b", fields: [domain_b_id], references: [id])

  @@index([domain_a_id, domain_b_id])
}

model signals {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id            String    @db.Uuid
  domain_id          String?   @db.Uuid
  content            String
  observation_period Int?
  submitted_at       DateTime  @default(now()) @db.Timestamptz
  lifecycle_status   String    @default("CANDIDATE")
  is_quarantined     Boolean   @default(false)
  is_connected       Boolean   @default(false)
  is_wsp_protected   Boolean   @default(false)
  mismatch_type      String?
  deviation_direction String?
  shg_mode           String    @default("PENDING")
  si_rate            Decimal?  @db.Decimal(4, 3)
  si_direction       Decimal?  @db.Decimal(4, 3)
  si_relationship    Decimal?  @db.Decimal(4, 3)
  si_configuration   Decimal?  @db.Decimal(4, 3)
  si_score           Decimal?  @db.Decimal(4, 3)
  si_subcriteria     String?
  sig_si             Decimal?  @db.Decimal(4, 3)
  sig_persistence    Decimal?  @db.Decimal(4, 3)
  sig_corroboration  Decimal?  @db.Decimal(4, 3)
  sig_proximity      Decimal?  @db.Decimal(4, 3)
  sig_rarity         Decimal?  @db.Decimal(4, 3)
  sig_relevance      Decimal?  @db.Decimal(4, 3)
  significance       Decimal?  @db.Decimal(4, 3)
  admitted_at        DateTime? @db.Timestamptz
  admission_reason   String?
  rejection_reason   String?
  rejection_lp       String?
  resolved_at        DateTime? @db.Timestamptz
  resolution_basis   String?
  original_signal_id String?   @db.Uuid
  ai_si_score        Decimal?  @db.Decimal(4, 3)
  ai_significance    Decimal?  @db.Decimal(4, 3)
  ai_reasoning       String?

  case                    cases                @relation(fields: [case_id], references: [id], onDelete: Cascade)
  domain                  domains?             @relation(fields: [domain_id], references: [id])
  original_signal         signals?             @relation("recurrence", fields: [original_signal_id], references: [id])
  recurrences             signals[]            @relation("recurrence")
  signal_events           signal_events[]
  admission_audit         admission_audit[]
  admission_audit_sealed  admission_audit_sealed[]
  score_change_audit      score_change_audit[]
  connections_as_a        signal_connections[] @relation("signal_a")
  connections_as_b        signal_connections[] @relation("signal_b")
  contradictions_as_a     contradictions[]     @relation("contra_a")
  contradictions_as_b     contradictions[]     @relation("contra_b")
  resolved_contradictions contradictions[]     @relation("resolved_signal")
  released_options        released_options[]
  hypothesis_evidence     hypothesis_evidence[]
  residual_instances      residual_instance[]

  @@index([case_id])
  @@index([domain_id])
  @@index([case_id, lifecycle_status])
  @@index([case_id, significance(sort: Desc)])
  @@index([case_id, si_score(sort: Desc)])
}

model signal_events {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  signal_id         String   @db.Uuid
  case_id           String   @db.Uuid
  from_status       String?
  to_status         String
  governance_change String?
  reason            String
  lp_flag           String?
  job_run_id        String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz

  signal signals @relation(fields: [signal_id], references: [id], onDelete: Cascade)
  case   cases   @relation(fields: [case_id], references: [id])

  @@index([signal_id])
  @@index([case_id, created_at(sort: Desc)])
}

model admission_audit {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  signal_id        String   @db.Uuid
  case_id          String   @db.Uuid
  decision         String
  si_score         Decimal? @db.Decimal(4, 3)
  significance     Decimal? @db.Decimal(4, 3)
  si_threshold     Decimal  @db.Decimal(4, 3)
  sig_threshold    Decimal  @db.Decimal(4, 3)
  rejection_reason String?
  decided_at       DateTime @default(now()) @db.Timestamptz

  signal signals @relation(fields: [signal_id], references: [id])
  case   cases   @relation(fields: [case_id], references: [id])

  @@index([case_id])
  @@index([case_id, decision])
}

model admission_audit_sealed {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq                Int      @default(autoincrement())
  signal_id          String   @db.Uuid
  case_id            String   @db.Uuid
  decision           String
  si_score           Decimal  @db.Decimal(5, 4)
  si_threshold       Decimal  @db.Decimal(5, 4)
  significance       Decimal  @db.Decimal(5, 4)
  sig_threshold      Decimal  @db.Decimal(5, 4)
  dim_threshold      Decimal  @db.Decimal(5, 4)
  constraint_version String
  signal_content     String
  si_rate            Decimal  @db.Decimal(5, 4)
  si_direction       Decimal  @db.Decimal(5, 4)
  si_relationship    Decimal  @db.Decimal(5, 4)
  si_configuration   Decimal  @db.Decimal(5, 4)
  input_hash          String   @db.Char(64)
  decision_trace      Json
  prev_hash           String   @db.Char(64)
  current_hash        String   @unique @db.Char(64)
  rtt_theory_version  String   @default("pre-versioning")
  sealed_at           DateTime @default(now()) @db.Timestamptz

  signal              signals              @relation(fields: [signal_id], references: [id])
  case                cases                @relation(fields: [case_id], references: [id])
  frame_relationships frame_relationship[]

  @@index([case_id])
  @@index([signal_id])
  @@index([seq])
}

model admission_audit_checkpoint {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq_from     Int
  seq_to       Int
  record_count Int
  merkle_root  String   @db.Char(64)
  created_at   DateTime @default(now()) @db.Timestamptz

  @@index([created_at(sort: Desc)])
}

model score_change_audit {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  signal_id                String   @db.Uuid
  case_id                  String   @db.Uuid
  changed_by               String   @default("INVESTIGATOR")
  before_si_score          Decimal? @db.Decimal(4, 3)
  after_si_score           Decimal? @db.Decimal(4, 3)
  before_si_rate           Decimal? @db.Decimal(4, 3)
  after_si_rate            Decimal? @db.Decimal(4, 3)
  before_si_direction      Decimal? @db.Decimal(4, 3)
  after_si_direction       Decimal? @db.Decimal(4, 3)
  before_si_relationship   Decimal? @db.Decimal(4, 3)
  after_si_relationship    Decimal? @db.Decimal(4, 3)
  before_si_configuration  Decimal? @db.Decimal(4, 3)
  after_si_configuration   Decimal? @db.Decimal(4, 3)
  before_significance      Decimal? @db.Decimal(4, 3)
  after_significance       Decimal? @db.Decimal(4, 3)
  reason                   String
  changed_at               DateTime @default(now()) @db.Timestamptz

  signal signals @relation(fields: [signal_id], references: [id])
  case   cases   @relation(fields: [case_id], references: [id])

  @@index([signal_id])
  @@index([case_id])
}

model signal_connections {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id                 String    @db.Uuid
  signal_a_id             String    @db.Uuid
  signal_b_id             String    @db.Uuid
  domain_a_id             String    @db.Uuid
  domain_b_id             String    @db.Uuid
  mismatch_type_match     Boolean   @default(false)
  dimension_match         Boolean   @default(false)
  temporal_match          Boolean   @default(false)
  direction_match         Boolean   @default(false)
  correspondence_strength Decimal   @db.Decimal(4, 3)
  domains_independent     Boolean
  independence_basis      String?
  shg_triggered           Boolean   @default(false)
  shg_triggered_at        DateTime? @db.Timestamptz
  hypothesis_id           String?   @db.Uuid
  created_at              DateTime  @default(now()) @db.Timestamptz

  case      cases      @relation(fields: [case_id], references: [id])
  signal_a  signals    @relation("signal_a", fields: [signal_a_id], references: [id])
  signal_b  signals    @relation("signal_b", fields: [signal_b_id], references: [id])
  domain_a  domains    @relation("domain_a", fields: [domain_a_id], references: [id])
  domain_b  domains    @relation("domain_b", fields: [domain_b_id], references: [id])
  hypothesis hypotheses? @relation("connection_hypothesis")

  @@unique([signal_a_id, signal_b_id])
  @@index([case_id])
  @@index([case_id, shg_triggered])
}

model contradictions {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id            String    @db.Uuid
  signal_a_id        String    @db.Uuid
  signal_b_id        String    @db.Uuid
  description        String
  status             String    @default("ACTIVE")
  resolution_type    String?
  resolution_basis   String?
  resolved_signal_id String?   @db.Uuid
  resolved_at        DateTime? @db.Timestamptz
  created_at         DateTime  @default(now()) @db.Timestamptz

  case            cases    @relation(fields: [case_id], references: [id])
  signal_a        signals  @relation("contra_a", fields: [signal_a_id], references: [id])
  signal_b        signals  @relation("contra_b", fields: [signal_b_id], references: [id])
  resolved_signal signals? @relation("resolved_signal", fields: [resolved_signal_id], references: [id])
  released_options released_options[]

  @@unique([signal_a_id, signal_b_id])
  @@index([case_id])
}

model released_options {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id          String    @db.Uuid
  contradiction_id String?   @db.Uuid
  signal_id        String?   @db.Uuid
  text             String
  is_active        Boolean   @default(true)
  flagged_at       DateTime? @db.Timestamptz
  unflag_reason    String?
  created_at       DateTime  @default(now()) @db.Timestamptz

  case         cases          @relation(fields: [case_id], references: [id])
  contradiction contradictions? @relation(fields: [contradiction_id], references: [id])
  signal       signals?        @relation(fields: [signal_id], references: [id])

  @@index([case_id, is_active])
}

model competition_sets {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id     String   @db.Uuid
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz

  case       cases        @relation(fields: [case_id], references: [id])
  hypotheses hypotheses[]
}

model hypotheses {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id                    String    @db.Uuid
  title                      String
  description                String
  hypothesis_type            String
  plausibility               Decimal   @default(0.50) @db.Decimal(4, 3)
  plausibility_basis         String?
  status                     String    @default("ACTIVE")
  competition_set_id         String?   @db.Uuid
  generated_by               String    @default("SHG")
  connection_id              String?   @unique @db.Uuid
  independence_basis_changed Boolean   @default(false)
  needs_resolution_review    Boolean   @default(false)
  resolved_at                DateTime? @db.Timestamptz
  resolution_basis           String?
  created_at                 DateTime  @default(now()) @db.Timestamptz
  updated_at                 DateTime  @default(now()) @db.Timestamptz

  case            cases              @relation(fields: [case_id], references: [id])
  competition_set competition_sets?  @relation(fields: [competition_set_id], references: [id])
  connection      signal_connections? @relation("connection_hypothesis", fields: [connection_id], references: [id])
  evidence        hypothesis_evidence[]
  plausibility_history plausibility_history[]

  @@index([case_id])
  @@index([case_id, status])
}

model hypothesis_evidence {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hypothesis_id     String   @db.Uuid
  case_id           String   @db.Uuid
  signal_id         String?  @db.Uuid
  content           String
  evidence_type     String
  weight            Decimal  @default(0.50) @db.Decimal(4, 3)
  plausibility_delta Decimal? @db.Decimal(5, 4)
  submitted_at      DateTime @default(now()) @db.Timestamptz

  hypothesis hypotheses @relation(fields: [hypothesis_id], references: [id], onDelete: Cascade)
  case       cases      @relation(fields: [case_id], references: [id])
  signal     signals?   @relation(fields: [signal_id], references: [id])
  plausibility_history plausibility_history[]

  @@unique([hypothesis_id, signal_id])
  @@index([hypothesis_id])
  @@index([signal_id])
}

model plausibility_history {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hypothesis_id String   @db.Uuid
  plausibility  Decimal  @db.Decimal(4, 3)
  reason        String
  evidence_id   String?  @db.Uuid
  job_run_id    String?  @db.Uuid
  recorded_at   DateTime @default(now()) @db.Timestamptz

  hypothesis hypotheses          @relation(fields: [hypothesis_id], references: [id])
  evidence   hypothesis_evidence? @relation(fields: [evidence_id], references: [id])

  @@index([hypothesis_id, recorded_at])
}

model briefings {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id             String   @db.Uuid
  signals_candidate   Int      @default(0)
  signals_admitted    Int      @default(0)
  signals_retained    Int      @default(0)
  signals_quarantined Int      @default(0)
  signals_connected   Int      @default(0)
  signals_assessed    Int      @default(0)
  signals_resolved    Int      @default(0)
  signals_archived    Int      @default(0)
  signals_expired     Int      @default(0)
  lp_flags_since_last String[]
  summary             String?
  content             Json
  generated_at        DateTime @default(now()) @db.Timestamptz

  case cases @relation(fields: [case_id], references: [id])

  @@index([case_id, generated_at(sort: Desc)])
}

model job_runs {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_name         String
  started_at       DateTime  @default(now()) @db.Timestamptz
  completed_at     DateTime? @db.Timestamptz
  records_affected Int       @default(0)
  status           String    @default("RUNNING")
  error_message    String?

  @@index([job_name, started_at(sort: Desc)])
}

model analytics_snapshots {
  id                           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshot_at                  DateTime @default(now()) @db.Timestamptz
  total_cases                  Int      @default(0)
  total_domains                Int      @default(0)
  total_signals_submitted      Int      @default(0)
  total_signals_admitted       Int      @default(0)
  total_hypotheses             Int      @default(0)
  total_hypotheses_confirmed   Int      @default(0)
  total_contradictions         Int      @default(0)
  total_contradictions_resolved Int     @default(0)
  total_briefings              Int      @default(0)
  lp1_count                    Int      @default(0)
  lp2_count                    Int      @default(0)
  lp3_count                    Int      @default(0)
  lp4_count                    Int      @default(0)
  lp5_count                    Int      @default(0)
  lp6_count                    Int      @default(0)
  lp7_count                    Int      @default(0)
  admission_rate               Decimal? @db.Decimal(5, 4)
  hcl_confirmation_rate        Decimal? @db.Decimal(5, 4)
  shg_trigger_rate             Decimal? @db.Decimal(5, 4)
  avg_si_score                 Decimal? @db.Decimal(4, 3)
  avg_significance             Decimal? @db.Decimal(4, 3)
}

// ── Residual Graph v1.3 ───────────────────────────────────────────────────
// EE_CIS_RESIDUAL_v1.3 — TRANSFORMED terminal state, transformation tracking,
// intervention optimization. Tables created via 0004_residual_graph migration.

model residual_type {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  description String?
  weight      Decimal  @default(1.0) @db.Decimal(4, 2)
  domain      String?
  created_at  DateTime @default(now()) @db.Timestamptz

  instances    residual_instance[]
  trajectories residual_trajectory[]
  clusters_as_source residual_cluster[] @relation("cluster_source")
  clusters_as_target residual_cluster[] @relation("cluster_target")
}

model residual_instance {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id          String   @db.Uuid
  residual_type_id String   @db.Uuid
  signal_id        String?  @db.Uuid
  description      String?
  weight           Decimal? @db.Decimal(4, 2)
  status           String   @default("open")
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @db.Timestamptz

  case          cases          @relation(fields: [case_id], references: [id], onDelete: Cascade)
  residual_type residual_type  @relation(fields: [residual_type_id], references: [id])
  signal        signals?       @relation(fields: [signal_id], references: [id])
  lineages              residual_lineage[]
  interventions              residual_intervention[]
  recommendation_events      recommendation_event[]
  propagation_events_sourced residual_propagation_event[] @relation("propagation_source")
  propagation_events_targeted residual_propagation_event[] @relation("propagation_target")

  @@index([case_id])
  @@index([residual_type_id])
  @@index([case_id, status])
}

model residual_lineage {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  residual_instance_id    String    @db.Uuid
  case_id                 String    @db.Uuid
  terminal_state          String    @default("ongoing")
  transformation_products Json      @default("[]")
  transformation_weight   Decimal?  @db.Decimal(4, 2)
  opened_at               DateTime  @default(now()) @db.Timestamptz
  closed_at               DateTime? @db.Timestamptz
  closure_note            String?

  residual_instance residual_instance   @relation(fields: [residual_instance_id], references: [id], onDelete: Cascade)
  case              cases               @relation(fields: [case_id], references: [id], onDelete: Cascade)
  interventions     residual_intervention[]

  @@index([residual_instance_id])
  @@index([case_id])
  @@index([terminal_state])
}

model residual_trajectory {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  residual_type_id       String   @db.Uuid
  subtype_tag            String?
  observation_count      Int      @default(0)
  resolved_count         Int      @default(0)
  persistent_count       Int      @default(0)
  transformed_count      Int      @default(0)
  endpoint_predictions   Json     @default("{}")
  transformation_targets Json     @default("{}")
  last_updated           DateTime @default(now()) @db.Timestamptz

  residual_type residual_type @relation(fields: [residual_type_id], references: [id])

  @@index([residual_type_id])
}

model residual_cluster {
  id                           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cluster_type                 String
  source_type_id               String   @db.Uuid
  target_type_id               String   @db.Uuid
  observation_count            Int      @default(0)
  co_occurrence_probability    Decimal? @db.Decimal(3, 2)
  transformation_probability   Decimal? @db.Decimal(3, 2)
  transformation_weight_expected Decimal? @db.Decimal(4, 2)
  // net_debt_delta is a generated column — not in Prisma model, read via raw SQL
  last_updated                 DateTime @default(now()) @db.Timestamptz

  source_type residual_type @relation("cluster_source", fields: [source_type_id], references: [id])
  target_type residual_type @relation("cluster_target", fields: [target_type_id], references: [id])

  @@unique([cluster_type, source_type_id, target_type_id])
  @@index([source_type_id])
  @@index([target_type_id])
  @@index([cluster_type])
}

model recommendation_event {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  residual_instance_id    String    @db.Uuid
  generated_at            DateTime  @default(now()) @db.Timestamptz
  candidate_actions       Json      @default("[]")
  recommended_action      String?
  expected_debt_delta     Decimal?  @db.Decimal(4, 2)
  chosen_action           String?
  followed_recommendation Boolean?
  actual_terminal_state   String?
  actual_debt_delta       Decimal?  @db.Decimal(4, 2)
  prediction_error        Decimal?  @db.Decimal(4, 3)
  rtt_theory_version      String    @default("v1.9")
  created_at              DateTime  @default(now()) @db.Timestamptz

  residual_instance residual_instance @relation(fields: [residual_instance_id], references: [id])

  @@index([residual_instance_id])
  @@index([followed_recommendation, actual_terminal_state])
  @@map("recommendation_event")
}

model residual_intervention {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lineage_id             String    @db.Uuid
  residual_instance_id   String    @db.Uuid
  case_id                String    @db.Uuid
  intervention_type      String
  intervention_note      String?
  outcome_terminal_state String?
  ecology_class          String?
  attempted_at           DateTime  @default(now()) @db.Timestamptz

  lineage           residual_lineage   @relation(fields: [lineage_id], references: [id], onDelete: Cascade)
  residual_instance residual_instance  @relation(fields: [residual_instance_id], references: [id])
  case              cases              @relation(fields: [case_id], references: [id])

  @@index([lineage_id])
  @@index([case_id])
}

model residual_propagation_event {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_instance_id     String    @db.Uuid
  target_instance_id     String    @db.Uuid
  propagation_channel    String
  attribution_confidence Decimal   @db.Decimal(3, 2)
  attribution_category   String
  occurred_at            DateTime? @db.Timestamptz
  detected_at            DateTime  @default(now()) @db.Timestamptz
  recorded_by            String?
  notes                  String?
  created_at             DateTime  @default(now()) @db.Timestamptz

  source_instance residual_instance @relation("propagation_source", fields: [source_instance_id], references: [id])
  target_instance residual_instance @relation("propagation_target", fields: [target_instance_id], references: [id])

  @@index([source_instance_id])
  @@index([target_instance_id])
  @@map("residual_propagation_event")
}

// ── CIS v2 Frame Graph ────────────────────────────────────────────────────
// Tables created via migration_frame_graph.sql (outside Prisma migrate).
// Models added here for Prisma type safety; raw SQL used for writes because
// generated columns (rtt_version_major/minor) are not representable in Prisma.

model frame_entity {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identity                   String
  level                      String
  case_id                    String?  @db.Uuid
  c_value                    Decimal? @db.Decimal(3, 1)
  r_state                    String?
  r_confidence               Decimal? @db.Decimal(3, 2)
  topology_type              String?
  sig_contradiction_density  Int      @default(0)
  sig_exception_proliferation Int     @default(0)
  sig_ontology_patch         Int      @default(0)
  sig_category_instability   Int      @default(0)
  sig_authority_drift        Int      @default(0)
  sig_reinterpretation       Int      @default(0)
  sig_recurrent_loop         Int      @default(0)
  rtt_theory_version         String   @default("pre-versioning")
  created_at                 DateTime @default(now()) @db.Timestamptz
  last_updated               DateTime @default(now()) @db.Timestamptz

  cases                      cases?   @relation(fields: [case_id], references: [id])
  outgoing_relationships     frame_relationship[] @relation("source_frame")
  incoming_relationships     frame_relationship[] @relation("target_frame")

  @@index([case_id])
  @@index([level])
  @@index([r_state])
  @@index([topology_type])
  @@index([rtt_theory_version])
}

model frame_relationship {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_frame_id   String   @db.Uuid
  target_frame_id   String   @db.Uuid
  relationship_type String
  direction         String
  strength          Decimal? @db.Decimal(3, 2)
  activated_at_r    String?
  audit_record_id   String?  @db.Uuid
  rtt_theory_version String  @default("pre-versioning")
  created_at        DateTime @default(now()) @db.Timestamptz

  source_frame frame_entity           @relation("source_frame", fields: [source_frame_id], references: [id])
  target_frame frame_entity           @relation("target_frame", fields: [target_frame_id], references: [id])
  audit_record admission_audit_sealed? @relation(fields: [audit_record_id], references: [id])

  @@index([source_frame_id])
  @@index([target_frame_id])
  @@index([relationship_type])
  @@index([audit_record_id])
  @@index([rtt_theory_version])
}
